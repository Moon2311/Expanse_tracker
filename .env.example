# =============================================================================
# Spendly — copy this file to `.env` and replace placeholder values.
# =============================================================================
# Committed templates (.env.example) are safe. Never commit a real `.env`.
#
# Where each app reads from:
#   • Flask (if you use the root app):  `.env` in the repo root, run from root.
#   • Django API:                       `backend/.env` — or symlink: `ln -s ../.env backend/.env`
#   • React (Vite):                     `frontend/.env` — see `frontend/.env.example`
#
# Tokens & credentials you must provide (no third-party API keys required):
#   • FLASK_SECRET_KEY    — you generate (session cookies).
#   • DJANGO_SECRET_KEY   — you generate (Django signing, JWT-related settings).
#   • DB_*                — your PostgreSQL user/password (you create in Postgres).
#
# Things you do NOT put in .env for this repo:
#   • GitHub Actions pushes to GHCR using `GITHUB_TOKEN` (GitHub injects it).
#   • Kubernetes: same variable *names* as below, but stored in a Secret / vault,
#     not necessarily in a file on disk in the cluster.
# =============================================================================

# --- Flask (classic server-rendered app) ------------------------------------
# Generate e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
FLASK_SECRET_KEY=change-me-long-random-string

# --- PostgreSQL (shared by Flask and Django) ----------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=spendly
DB_USER=postgres
DB_PASSWORD=your-postgres-pass

# --- Django REST API (backend/) ----------------------------------------------
# Generate a separate long random string (not the same as FLASK_SECRET_KEY).
DJANGO_SECRET_KEY=change-me-another-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Browser origins allowed to call the API (comma-separated, no spaces unless in URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Access token lifetime for JWT login (minutes)
JWT_ACCESS_MINUTES=60

# --- Optional: Docker / Gunicorn (container entrypoint reads this) -----------
# WEB_CONCURRENCY=3
