# =============================================================================
# Django API — copy to `backend/.env` (or symlink ../.env from repo root).
# =============================================================================
# Full project reference: `../.env.example` (includes Flask + same DB vars).
#
# Required secrets (you generate / own):
#   DJANGO_SECRET_KEY  — random string (Django security signing).
#   DB_PASSWORD        — your PostgreSQL password.
#   DB_USER, DB_NAME   — your PostgreSQL database and role.
#
# No OAuth/API keys are required for core Spendly API features.
# =============================================================================

DJANGO_SECRET_KEY=change-me-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=spendly
DB_USER=postgres
DB_PASSWORD=your-postgres-password

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_ACCESS_MINUTES=60
