# =============================================================================
# React (Vite) — copy to `frontend/.env` or `frontend/.env.local`
# =============================================================================
# Only variables prefixed with VITE_ are exposed to the browser.
# Do not put database passwords or Django secrets here.
#
# Local dev: leave VITE_API_BASE empty so `/api` is proxied to Django (port 8000).
# Production build: set to your public API URL, including the `/api` path if that
# is how your backend is mounted (must match CORS_ALLOWED_ORIGINS on the server).
# =============================================================================

# Empty = Vite dev server proxies /api → http://127.0.0.1:8000
VITE_API_BASE=

# Example for deployed API:
# VITE_API_BASE=https://api.yourdomain.com/api
